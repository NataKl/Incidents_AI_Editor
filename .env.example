# AI_Editor — docker compose подхватывает .env автоматически.
# Скопируйте этот файл в .env и заполните реальные значения локально.
# Не коммитьте .env с паролями, токенами и приватными прокси.

# --- Nginx (фронт / reverse proxy) ---
HTTP_PORT=80
HTTPS_PROXY=
# Требуются настройки страны/прокси, если OPENAI недоступен из вашей сети.

# --- pgAdmin ---
# Register Server:
# Host=db | Port=5432 | Maintenance database=ai_editor
# Username=admin_editor | Password=значение POSTGRES_PASSWORD
PGADMIN_IMAGE_TAG=8
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me
PGADMIN_MAX_LOGIN_ATTEMPTS=0

# --- Docker Registry (образы бэка) ---
REGISTRY_PORT=5000
REGISTRY_USER=registryuser
REGISTRY_AUTH_REALM="AI Editor Docker Registry"

# --- PostgreSQL ---
POSTGRES_DB=ai_editor
POSTGRES_USER=admin_editor
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_INITDB_ARGS=--encoding=UTF-8
POSTGRES_IMAGE=postgres:16-alpine

# --- Watchtower ---
WATCHTOWER_STOP_TIMEOUT=30s

# --- Backend: опционально ИИ-диагностика ---
# Без ключа приложение должно использовать эвристику, если это поддержано backend.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini-2025-08-07
#OPENAI_TEMPERATURE=0.7
OPENAI_BASE_URL=https://api.openai.com/v1
